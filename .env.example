# Copy to .env and fill in real values. Never commit the real .env.

DATABASE_URL="file:./dev.db"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# Django backend (see /backend) — auth and teacher-profile data come from here.
DJANGO_API_URL="http://localhost:8000"
NEXT_PUBLIC_DJANGO_API_URL="http://localhost:8000"

# Used to build absolute links (Stripe success/cancel URLs). Password-reset
# links are now built by the Django backend (FRONTEND_URL in backend/.env.example).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (booking checkout is not yet ported to Django — see TODOS.md).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
