# Copy to .env and fill in real values. Never commit the real .env.

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# Django backend (see /backend) — auth, teacher-profile data, bookings, and
# Stripe checkout all live there now.
DJANGO_API_URL="http://localhost:8000"
NEXT_PUBLIC_DJANGO_API_URL="http://localhost:8000"

# Google OAuth (NextAuth Google provider). Create a client at
# console.cloud.google.com, add {origin}/api/auth/callback/google to the
# authorized redirect URIs. Client ID also goes in backend/.env (GOOGLE_CLIENT_ID).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
